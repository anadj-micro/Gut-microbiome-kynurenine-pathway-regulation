#!/usr/bin/env Rscript
# Script to run dada2 for inferring sequence variants.
# Line 23: This command is written for fastq files generated in this project. If re-using
# this script for other projects, update the line according to the names of the new fastq files.
# Make sure to setup path to the "output" folder where fastq files are. For example:
# path <- "~/Documents/Analysis/dada2/output"
path <- "/Users/ana/Library/CloudStorage/OneDrive-CentrodeInvestigaciónPríncipeFelipe/Projects/IDO/KP/GitHub_repository/16S_amplicon_sequence_processing/output"
library(dada2); packageVersion("dada2")
#forward
fnFs <- Sys.glob(file.path(path, "*_R1*.fastq.gz"))
#backward
fnRs <- Sys.glob(file.path(path, "*_R2*.fastq.gz"))
forwardfileinfo <- file.info(fnFs)
forwardsizes <- forwardfileinfo[,"size"]
reversefileinfo <- file.info(fnRs)
reversesizes <- forwardfileinfo[,"size"]
#get sample names (update depending on filename conventions)
sample.names <- sapply(strsplit(sapply(strsplit(basename(fnFs), ".fastq.gz"), `[`, 1), "fastq_"), `[`,2)
#
#temporary files for storing filtered data
filtFs <- file.path(path, "filtered", paste0(sample.names, "_F_filt.fastq.gz"))
filtRs <- file.path(path, "filtered", paste0(sample.names, "_R_filt.fastq.gz"))
out <- filterAndTrim(fnFs, filtFs, fnRs, filtRs, truncLen=c(180,180),
maxN=0, maxEE=2, truncQ=2,
compress=TRUE, multithread=TRUE)
exists <- file.exists(filtFs) & file.exists(filtRs)
filtFs <- filtFs[exists]
filtRs <- filtRs[exists]
errF <- learnErrors(filtFs, multithread=TRUE)
errR <- learnErrors(filtRs, multithread=TRUE)
derepFs <- derepFastq(filtFs, verbose=TRUE)
derepRs <- derepFastq(filtRs, verbose=TRUE)
if(!inherits(derepFs,"list")){
derepFs <- list(derepFs)
derepRs <- list(derepRs)
}
names(derepFs) <- sample.names[exists]
names(derepRs) <- sample.names[exists]
dadaFs <- dada(derepFs, err=errF,multithread=TRUE)
dadaRs <- dada(derepRs, err=errR,multithread=TRUE)
mergers <- mergePairs(dadaFs, derepFs, dadaRs, derepRs, verbose=TRUE)
seqtab <- makeSequenceTable(mergers)
seqtab.nochim <- removeBimeraDenovo(seqtab, method="consensus", multithread=TRUE, verbose=TRUE)
seqtabfinal <- seqtab.nochim[,nchar(colnames(seqtab.nochim)) %in% seq(300,360)]
outfile <- file.path(path, 'seqtab_noprior.rds')
saveRDS(seqtabfinal, file=outfile)
outfile <- file.path(path, 'errR.rds')
saveRDS(errR, file=outfile)
outfile <- file.path(path, 'errF.rds')
saveRDS(errF, file=outfile)
outfile <- file.path(path, 'derepFs.rds')
saveRDS(derepFs, file=outfile)
outfile <- file.path(path, 'derepRs.rds')
saveRDS(derepRs, file=outfile)
datadir <- "/Users/ana/Library/CloudStorage/OneDrive-CentrodeInvestigaciónPríncipeFelipe/Projects/IDO/KP/GitHub_repository/16S_amplicon_sequence_processing"
finaltbldir <- "final_tables"
if (file.exists(file.path(datadir, finaltbldir))){
setwd(file.path(datadir))
} else {
dir.create(file.path(datadir, finaltbldir))
setwd(file.path(datadir))
}
library(dada2)
library(reshape2)
# load counts table from previous runs if there are any
if (file.exists(file.path(finaltbldir,"tblASVcounts.csv"))) {
prevtblASVcounts <- read.csv(file.path(finaltbldir,"tblASVcounts.csv"), header = TRUE)
} else {
prevtblASVcounts <- data.frame(matrix(ncol = 3, nrow = 0))
x <- c("Sample.ID", "ASV", "count")
colnames(prevtblASVcounts) <- x
}
prevcolnames <- colnames(prevtblASVcounts)
#load master list
if (file.exists(file.path(finaltbldir,"ASV2seq.csv"))) {
masterASV2seq <- read.csv(file.path(finaltbldir,"ASV2seq.csv"), header = TRUE)
} else {
masterASV2seq <- data.frame(matrix(ncol = 2, nrow = 0))
x <- c("ASV", "sequence")
colnames(masterASV2seq) <- x
}
currseqtab <- readRDS(file.path(datadir,"output/seqtab_noprior.rds"))
meltcurrsampletable <- melt(currseqtab)
addsampletable <- meltcurrsampletable[meltcurrsampletable$value!=0,]
colnames(addsampletable) <- c("Sample.ID","sequence","count")
uniquesequences <- unique(addsampletable$sequence)
#find sequences not contained in master list, assign them a name and output files to merge with master list
newsequences2master <- setdiff(uniquesequences,masterASV2seq$sequence)
if( length(newsequences2master)>0 ){
prevmaxidx <- dim(masterASV2seq)[1]
#generate new ASV tbl to get taxonomy
newASVtbl <- data.frame("ASV" = paste('ASV_',(prevmaxidx+1):(prevmaxidx+length(newsequences2master)),sep=""), "sequence" = newsequences2master)
#write.csv(newASVtbl,file=file.path(tmpdir,"ASVsequences_pre.csv"),quote=FALSE,row.names=FALSE)
masterASV2seq <- rbind(masterASV2seq,newASVtbl)
write.csv(masterASV2seq,file=file.path(finaltbldir,"ASV2seq.csv"),quote=FALSE,row.names=FALSE)
}
fullsubmaster <- masterASV2seq[match(uniquesequences,masterASV2seq$sequence),c("ASV","sequence")]
addsampletable$ASV <- fullsubmaster$ASV[match(addsampletable$sequence,fullsubmaster$sequence)]
addsampletable1 <- addsampletable
addsampletable$sequence <- NULL
addsampletable <- addsampletable[c("Sample.ID","ASV","count")]
#colnames(addsampletable)[which(colnames(addsampletable) == "value")] <- "count"
newtblASVcount <- rbind(prevtblASVcounts,addsampletable)
#newtblASVcount <- newtblASVcount[c("Sample.ID","ASV","count")]
write.csv(newtblASVcount,file=file.path(finaltbldir,"tblASVcounts.csv"),quote=FALSE,row.names=FALSE)
if( length(newsequences2master)>0 ){
#read again counts and seq tables that just have been updated
# prevtblASVcounts <- read.csv(file.path(finaltbldir,"tblASVcounts.csv"), header = TRUE)
# masterASV2seq <- read.csv(file.path(finaltbldir,"ASV2seq.csv"), header = TRUE)
#
# # to asign taxonomy on already existing asvcounts and seq files you need to modify tables
# # to make data matrix with sequence and abundance columns
# prevtblASVcounts$sequence <- masterASV2seq$sequence[match(prevtblASVcounts$ASV,masterASV2seq$ASV)]
# colnames(prevtblASVcounts)[3] <- "abundance"
# set.seed(100) # Initialize random number generator for reproducibility
# taxa.80 <- assignTaxonomy(prevtblASVcounts, "dada2_databases/silva_nr99_v138.1_train_set.fa.gz", minBoot=80)
# or focus on just new sequences
set.seed(100) # Initialize random number generator for reproducibility
colnames(addsampletable1)[3] <- "abundance"
taxa.80 <- assignTaxonomy(addsampletable1, "dada2_databases/silva_nr99_v138.1_train_set.fa.gz", minBoot=80)
unname(taxa.80)
#taxa.80.plus <- addSpecies(taxa.80, "dada2_databases/silva_species_assignment_v138.1.fa.gz", verbose=TRUE, n=1000)
set.seed(NULL)
if (file.exists(file.path(finaltbldir,"taxa.80.csv"))) {
master80 <- read.csv(file.path(finaltbldir,"taxa.80.csv"), header = TRUE)
master80 <- master80[,2:ncol(master80)]
#colnames(master80)[1] <- "sequence"
taxa.80 <- cbind(rownames(taxa.80), data.frame(taxa.80, row.names=NULL))
colnames(taxa.80)[1] <- "sequence"
finalnew80 <- rbind(master80,taxa.80)
} else {
finalnew80 <- taxa.80
}
write.csv(finalnew80,file=file.path(finaltbldir,"taxa.80.csv"),quote=FALSE, row.names = TRUE)
taxa.80 <- read.csv(file.path(finaltbldir,"taxa.80.csv"), header = TRUE)
taxa.80 <- taxa.80[,2:ncol(taxa.80)]
colnames(taxa.80) <- c("sequence", "kingdom", "phylum", "class", "order", "family", "genus")
taxa.80$ASV <- masterASV2seq$ASV[match(taxa.80$sequence,masterASV2seq$sequence)]
taxa.80 <- taxa.80[,c(8,1,2,3,4,5,6,7)]
taxa.80.1 <- unique(taxa.80)
taxa.80.1 <- as.data.frame.matrix(taxa.80.1)
library(dplyr)
# keep only lines with complete assginment including genus level
taxa.80.1 = taxa.80.1[order(taxa.80.1[,'ASV'],is.na(taxa.80.1[,'genus'])),]
taxa.80.1 = taxa.80.1[!duplicated(taxa.80.1$ASV),]
# test if there are more duplicated rows
a <- unique(taxa.80.1$ASV) # it matches the rowsize of taxa.80.1 so it's fine
taxa.80.1$kingdom[is.na(taxa.80.1$kingdom)] <- c("<not present>")
taxa.80.1$phylum[is.na(taxa.80.1$phylum)] <- c("<not present>")
taxa.80.1$class[is.na(taxa.80.1$class)] <- c("<not present>")
taxa.80.1$order[is.na(taxa.80.1$order)] <- c("<not present>")
taxa.80.1$family[is.na(taxa.80.1$family)] <- c("<not present>")
taxa.80.1$genus[is.na(taxa.80.1$genus)] <- c("<not present>")
write.csv(taxa.80.1,file=file.path(finaltbldir,"tblASVtaxonomy_dada2_plus.csv"),quote=FALSE,row.names=FALSE)
taxa.80.1 <- taxa.80.1[,-2]
write.csv(taxa.80.1, file=file.path(finaltbldir, "tblASVtaxonomy_dada2.csv"), quote=FALSE, row.names = FALSE)
#
# library(DECIPHER); packageVersion("DECIPHER")
# dna <- DNAStringSet(newASVtbl$sequence)
# load("idtaxa_databases/SILVA_SSU_r138_2019.RData")
# ids <- IdTaxa(dna, trainingSet, strand="both", processors=NULL, verbose=FALSE) # use all processors
